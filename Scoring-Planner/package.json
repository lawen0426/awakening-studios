{
  "name": "weekly-score-planner",
  "productName": "Film Scoring Weekly Planner",
  "description": "A macOS desktop planner for film scoring schedules, weekly writing targets, and timeline tracking.",
  "author": "Luanhui",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "dev:electron": "wait-on tcp:4173 && cross-env ELECTRON_START_URL=http://127.0.0.1:4173 node node_modules/electron/cli.js .",
    "build": "tsc -b && vite build",
    "desktop": "node node_modules/electron/cli.js .",
    "run:desktop": "npm run build && npm run desktop",
    "pack:mac": "npm run build && electron-builder --config electron-builder.config.cjs --mac dmg zip --arm64 --publish never",
    "pack:mac:universal": "npm run build && electron-builder --config electron-builder.config.cjs --mac dmg zip --universal --publish never",
    "release:github:check": "node scripts/github-release-check.mjs",
    "release:upload": "node scripts/upload-github-release.mjs",
    "release:ship": "npm run pack:mac && npm run release:upload",
    "release:publish": "node scripts/publish-github-release.mjs",
    "supabase:schema:check": "node scripts/check-supabase-schema.cjs",
    "supabase:connection:check": "node scripts/check-supabase-connection.cjs",
    "supabase:push": "npx supabase db push --db-url \"$SUPABASE_DB_URL\"",
    "supabase:push:dry-run": "npx supabase db push --dry-run --db-url \"$SUPABASE_DB_URL\"",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.2",
    "electron-updater": "^6.8.3",
    "html2canvas": "^1.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.4",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.luanhui.weeklyscoreplanner",
    "productName": "Film Scoring Weekly Planner",
    "afterSign": "electron/notarize.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music"
    }
  }
}
